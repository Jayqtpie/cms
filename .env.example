# bcrypt hash of the editor password — set with: npm run set-password
CMS_PASSWORD=
# random 64-char string (auto-generated by set-password if left blank)
JWT_SECRET=
PORT=4001
# Max upload size in MB for images/videos (default 64)
CMS_UPLOAD_MAX_MB=64
# Image pipeline: uploads are re-encoded to WebP, capped to this width (default
# 2000px) at this quality 1-100 (default 80). Videos and SVGs are left as-is.
CMS_IMAGE_MAX_WIDTH=2000
CMS_IMAGE_QUALITY=80
# Optional 2FA: base32 secret shared with an authenticator app. When set, login
# also requires the current 6-digit code. Leave blank to disable.
CMS_TOTP_SECRET=
# Optional extra cross-origin domains allowed to call the API (comma-separated),
# in addition to siteUrl from cms.site.json. E.g. https://www.example.com
CMS_ALLOWED_ORIGINS=
